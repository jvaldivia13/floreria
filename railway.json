{
  "$schema": "https://railway.app/schema/railway.json",
  "services": [
    {
      "name": "backend",
      "type": "nodejs",
      "path": "backend",
      "startCommand": "npm install && npm start",
      "envVariables": {
        "NODE_ENV": "production",
        "PORT": "5000"
      }
    },
    {
      "name": "frontend",
      "type": "static",
      "path": "frontend/dist",
      "buildCommand": "npm install && npm run build",
      "envVariables": {
        "VITE_API_URL": "https://floreria-production-4282.up.railway.app/api"
      }
    }
  ],
  "postgres": {
    "enabled": true,
    "version": "16"
  }
}
